{
  "name": "overbearer",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "e2e"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "dev:proxy": "npm run dev -w packages/proxy",
    "dev:api": "npm run dev -w packages/api",
    "dev:ui": "npm run dev -w packages/ui",
    "test": "npm test --workspaces --if-present",
    "test:e2e": "npm test -w e2e"
  }
}
